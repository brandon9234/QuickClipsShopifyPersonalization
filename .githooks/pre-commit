#!/usr/bin/env bash
set -euo pipefail

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoLogo -NoProfile -ExecutionPolicy Bypass -File QuickClipsPersonalization/update-ui-readme.ps1 >/dev/null
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File QuickClipsPersonalization/update-ui-readme.ps1 >/dev/null
else
  echo "Skipping README UI diff update: PowerShell not found."
  exit 0
fi

git add QuickClipsPersonalization/README.md
