<modal-dialog id="PersonalizationPreviewModal" class="personalization-preview-modal">
  <div
    role="dialog"
    aria-modal="true"
    aria-label="Personalization preview"
    class="personalization-preview-modal__content global-settings-popup"
    tabindex="-1"
  >
    <button
      id="ModalClose-PersonalizationPreviewModal"
      type="button"
      class="personalization-preview-modal__toggle"
      aria-label="{{ 'accessibility.close' | t }}"
    >
      {% render 'icon-close' %}
    </button>

    <div class="personalization-preview-modal__body">
      <div class="personalization-preview-modal__header">
        <h2 class="h3">Customize Your Product</h2>
        <p class="personalization-preview-modal__product" data-personalization-product-name hidden></p>
      </div>

      <div class="personalization-preview-modal__workspace">
        <div class="personalization-preview-modal__preview" aria-live="polite" data-personalization-picked-panel>
          <p class="personalization-preview-modal__preview-label">QuickClip preview workspace</p>
          <div
            class="personalization-preview-modal__blank-clip is-style-1"
            data-personalization-clip-surface
            data-personalization-stage-image-url="{{ 'HorizontalOGQuickClip.jpg' | asset_url }}"
          >
            <img
              class="personalization-preview-modal__style-preview-image"
              data-personalization-style-preview-image
              alt="Selected style preview"
              hidden
            >
            <div
              class="personalization-preview-modal__deterministic-overlay"
              data-personalization-deterministic-overlay
              hidden
            >
              <div class="personalization-preview-modal__deterministic-textbox">
                <p class="personalization-preview-modal__deterministic-line personalization-preview-modal__deterministic-line--name" data-personalization-deterministic-last-name></p>
                <p class="personalization-preview-modal__deterministic-line personalization-preview-modal__deterministic-line--date" data-personalization-deterministic-date></p>
              </div>
            </div>
          </div>
        </div>

        <div class="personalization-preview-modal__editor">
          <div class="personalization-preview-modal__fields">
            <div class="personalization-preview-modal__field">
              <p class="form__label">Choose clip style</p>
              <div class="personalization-preview-modal__style-options">
                <label class="personalization-preview-modal__style-option">
                  <input
                    type="radio"
                    name="PersonalizationStyle"
                    value="Style 1"
                    data-personalization-input="style"
                    checked
                  >
                  <span class="personalization-preview-modal__style-option-display">
                    <img
                      src="{{ 'quickclip-style-1.jpg' | asset_url }}"
                      alt="Style 1 preview"
                      class="personalization-preview-modal__style-option-image"
                      loading="lazy"
                    >
                    <span class="personalization-preview-modal__style-option-label">Style 1</span>
                  </span>
                </label>
                <label class="personalization-preview-modal__style-option">
                  <input
                    type="radio"
                    name="PersonalizationStyle"
                    value="Style 2"
                    data-personalization-input="style"
                  >
                  <span class="personalization-preview-modal__style-option-display">
                    <img
                      src="{{ 'quickclip-style-2.jpg' | asset_url }}"
                      alt="Style 2 preview"
                      class="personalization-preview-modal__style-option-image"
                      loading="lazy"
                    >
                    <span class="personalization-preview-modal__style-option-label">Style 2</span>
                  </span>
                </label>
                <label class="personalization-preview-modal__style-option">
                  <input
                    type="radio"
                    name="PersonalizationStyle"
                    value="Style 3"
                    data-personalization-input="style"
                  >
                  <span class="personalization-preview-modal__style-option-display">
                    <img
                      src="{{ 'quickclip-style-3.jpg' | asset_url }}"
                      alt="Style 3 preview"
                      class="personalization-preview-modal__style-option-image"
                      loading="lazy"
                    >
                    <span class="personalization-preview-modal__style-option-label">Style 3</span>
                  </span>
                </label>
              </div>
              <p class="personalization-preview-modal__helper">
                Upload style images in theme assets as: quickclip-style-1.jpg, quickclip-style-2.jpg, quickclip-style-3.jpg.
                Editing canvas image: HorizontalOGQuickClip.jpg
              </p>
            </div>

            <div class="personalization-preview-modal__field">
              <p class="personalization-preview-modal__helper">
                Style font presets are applied automatically based on the selected style.
              </p>
            </div>

            <div class="personalization-preview-modal__field-group">
              <div class="personalization-preview-modal__field">
                <label class="form__label" for="PersonalizationLastName">Last name</label>
                <input
                  id="PersonalizationLastName"
                  class="personalization-preview-modal__input"
                  type="text"
                  autocomplete="off"
                  placeholder="Ex: The Johnsons"
                  data-personalization-input="lastName"
                >
                <p class="personalization-preview-modal__count" data-personalization-count="lastName"></p>
              </div>

              <div class="personalization-preview-modal__field">
                <label class="form__label" for="PersonalizationDate">Date</label>
                <input
                  id="PersonalizationDate"
                  class="personalization-preview-modal__input"
                  type="text"
                  autocomplete="off"
                  placeholder="MM/DD/YYYY"
                  data-personalization-input="date"
                >
                <p class="personalization-preview-modal__count" data-personalization-count="date"></p>
              </div>
            </div>
          </div>

          <p class="personalization-preview-modal__error" role="alert" hidden data-personalization-error></p>

          <div class="personalization-preview-modal__actions">
            <button type="button" class="button button--secondary" data-personalization-cancel>Cancel</button>
            <button type="button" class="button button--secondary" data-personalization-generate>
              <span class="personalization-preview-modal__button-spinner" aria-hidden="true"></span>
              <span class="personalization-preview-modal__button-label" data-personalization-generate-label>Generate</span>
            </button>
            <button type="button" class="button" data-personalization-save>Save personalization</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</modal-dialog>
