{% comment %}
  Hidden line item properties synchronized by personalization-preview.js.

  Accepts:
  - product: {Object} Product object.
  - personalization_scope: {String} Unique scope for state isolation.
{% endcomment %}

{%- if product != blank and personalization_scope != blank -%}
  <div
    class="personalization-line-item-properties"
    data-personalization-context
    data-personalization-scope="{{ personalization_scope }}"
    data-personalization-product-id="{{ product.id }}"
  >
    <input
      type="hidden"
      name="properties[Personalization Primary Text]"
      value=""
      data-personalization-property="primary"
    >
    <input
      type="hidden"
      name="properties[Personalization Secondary Text]"
      value=""
      data-personalization-property="secondary"
    >
    <input
      type="hidden"
      name="properties[Personalization Style]"
      value="Style 1"
      data-personalization-property="style"
    >
    <input
      type="hidden"
      name="properties[Personalization Name 1]"
      value=""
      data-personalization-property="name1"
    >
    <input
      type="hidden"
      name="properties[Personalization Name 2]"
      value=""
      data-personalization-property="name2"
    >
    <input
      type="hidden"
      name="properties[Personalization Date]"
      value=""
      data-personalization-property="date"
    >
    <input
      type="hidden"
      name="properties[Personalization Mode]"
      value="ai"
      data-personalization-property="mode"
    >
    <input
      type="hidden"
      name="properties[Personalization Deterministic Text]"
      value=""
      data-personalization-property="deterministic_text"
    >
    <input
      type="hidden"
      name="properties[Personalization Deterministic Font]"
      value=""
      data-personalization-property="deterministic_font"
    >
    <input
      type="hidden"
      name="properties[Personalization Deterministic Size]"
      value=""
      data-personalization-property="deterministic_size"
    >
    <input
      type="hidden"
      name="properties[Personalization Deterministic Box Width]"
      value=""
      data-personalization-property="deterministic_box_width"
    >
    <input
      type="hidden"
      name="properties[_Personalization Gemini Preview]"
      value=""
      data-personalization-property="gemini_summary"
    >
    <input
      type="hidden"
      name="properties[_Personalization Scope]"
      value="{{ personalization_scope }}"
      data-personalization-property="scope"
    >
  </div>
{%- endif -%}
